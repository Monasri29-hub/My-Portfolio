{
    "name": "dynamic-flare",
    "version": "1.0.0",
    "description": "AI/ML Portfolio - Full Stack App",
    "type": "module",
    "scripts": {
        "dev": "concurrently \"npm run dev --prefix server\" \"npm run dev --prefix client\"",
        "build": "npm install --prefix client && npm run build --prefix client && npx prisma generate --schema=server/prisma/schema.prisma",
        "server": "npm run dev --prefix server",
        "client": "npm run dev --prefix client"
    },
    "dependencies": {
        "@prisma/client": "^5.22.0",
        "axios": "^1.13.5",
        "bcryptjs": "^3.0.3",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.6",
        "dotenv": "^17.2.4",
        "express": "^5.2.1",
        "express-async-handler": "^1.2.0",
        "framer-motion": "^12.34.0",
        "helmet": "^8.1.0",
        "jsonwebtoken": "^9.0.3",
        "lucide-react": "^0.563.0",
        "morgan": "^1.10.1",
        "multer": "^2.0.2",
        "react": "^19.2.0",
        "react-dom": "^19.2.0",
        "react-router-dom": "^7.13.0"
    },
    "devDependencies": {
        "concurrently": "^9.1.2",
        "prisma": "^5.22.0",
        "vite": "^7.3.1",
        "@vitejs/plugin-react": "^5.1.1"
    }
}